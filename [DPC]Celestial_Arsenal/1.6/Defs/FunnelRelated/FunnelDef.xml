<Defs>
  <ThingDef>
    <defName>TOT_Drone_Base</defName>
    <label>E.M.assault funnel</label>
    <description>A mobile Funnel that guards its master and attacks designated targets. Its aggressive AI makes it a priority target for enemy fire.</description>
    <thingClass>TOT_DLL_test.CMC_Drone</thingClass>
    <useHitPoints>true</useHitPoints>
	<uiIconPath>Things/Drone/CMC_DroneBase_UI</uiIconPath>
    <statBases>
      <MaxHitPoints>250</MaxHitPoints>
      <Flammability>0.7</Flammability>
      <MoveSpeed>6.5</MoveSpeed> 
	  <MarketValue>350</MarketValue>
    </statBases>
	<tickerType>Normal</tickerType>
	<selectable>false</selectable>
    <drawerType>MapMeshAndRealTime</drawerType>
	<category>Building</category>
    <building>
      <ai_combatDangerous>true</ai_combatDangerous>
	  <destroySound>BuildingDestroyed_Metal_Medium</destroySound>
	  <isEdifice>false</isEdifice>
	  <canBuildNonEdificesUnder>true</canBuildNonEdificesUnder>
    </building>
    <graphicData>
      <texPath>Things/CMC_Void</texPath> 
	  <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1,1)</drawSize>
    </graphicData>
    <altitudeLayer>Pawn</altitudeLayer>
    <pathCost>0</pathCost>
    <passability>Standable</passability>
    <fillPercent>0</fillPercent> 
	<isAutoAttackableMapObject>true</isAutoAttackableMapObject>
    <comps>
      <li Class="TOT_DLL_test.CompProperties_DroneMovement">
        <hoverRadiusMin>2</hoverRadiusMin>
        <hoverRadiusMax>2</hoverRadiusMax>
        <shadowTexPath>Things/Drone/CMC_Drone_Shadow</shadowTexPath>
		<CanManualControl>false</CanManualControl>
        <shadowSize>0.47</shadowSize>
		<turretDef>GUN_FunnelEMLMG</turretDef>
		<graphicDataTurret>
			<texPath>Things/Drone/CMC_DroneBase</texPath>
			<drawSize>(1,1)</drawSize>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>Cutout</shaderType>
		</graphicDataTurret>
		<graphicDataTurretOverlay>
			<texPath>Things/Drone/CMC_DroneBase_Light</texPath>
			<drawSize>(1,1)</drawSize>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>MoteGlow</shaderType>
		</graphicDataTurretOverlay>
      </li>
    </comps>
  </ThingDef>
  
