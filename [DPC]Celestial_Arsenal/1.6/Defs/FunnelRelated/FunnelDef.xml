  <ThingDef ParentName="BaseWeaponTurret">
		<defName>Gun_CMCFunnel_LaserLMG</defName>
		<label>escort DEW</label>
		<description>A miniaturized DEW compatible with armed floating platforms.</description>
		<tradeability>None</tradeability>
		<destroyOnDrop>true</destroyOnDrop>
		<graphicData>
			<texPath>Things/CMC_Void</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<statBases>
			<Mass>1.2</Mass>
			<AccuracyTouch>0.60</AccuracyTouch>
			<AccuracyShort>0.80</AccuracyShort>
			<AccuracyMedium>0.90</AccuracyMedium>
			<AccuracyLong>0.85</AccuracyLong>
		</statBases>
		<verbs>
      <li>
        <verbClass>TOT_DLL_test.Verb_Laser_Sustain</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <warmupTime>0</warmupTime>
        <range>19</range>
        <!--这个是攻击次数-->
        <burstShotCount>60</burstShotCount>
        <!--这个是攻击间隔-->
        <ticksBetweenBurstShots>2</ticksBetweenBurstShots>
        <soundCastTail>GunTail_Medium</soundCastTail>
        <muzzleFlashScale>0</muzzleFlashScale>
      </li>
    </verbs>
	<comps>
      <li Class="TOT_DLL_test.CompProperties_LaserData_Sustain">
        <!--激光光束样式-->
        <LaserLine_MoteDef>CMC_Laser_Stay_MoteBlue_NarrowUAV</LaserLine_MoteDef>
        <!--光束末端的效果+基础大小-->
        <LaserFleck_End>CMC_Laser_Stay_LaserEndLarge_TT</LaserFleck_End>
        <!--光束基础大小-->
        <LaserFleck_End_Scale_Base>1.5</LaserFleck_End_Scale_Base>
        <!--光束末端粒子的效果+基础大小+大小偏移量+数量+产生几率-->
        <LaserFleck_Spark>CMC_Stay_Laser_Spark</LaserFleck_Spark>
        <!--光束末端粒子的基础大小-->
        <LaserFleck_Spark_Scale_Base>0.11</LaserFleck_Spark_Scale_Base>
        <!--光束末端粒子大小偏移量-->
        <LaserFleck_Spark_Scale_Deviation>0.2</LaserFleck_Spark_Scale_Deviation>
        <!--光束末端粒子数量-->
        <LaserFleck_Spark_Num>3</LaserFleck_Spark_Num>
        <!--光束末端粒子产生几率-->
        <LaserFleck_Spark_Spawn_Chance>0.4</LaserFleck_Spark_Spawn_Chance>
        <!--这是开火时的音效-->
        <SoundDef>CMC_LaserSustainSound</SoundDef>
        <!--这是光束颜色调整（直接输入数值0-255）+不透明度（0-1）（如果是已经上好色的激光贴图的话，全部颜色写成255应该就行）-->
        <Color_Red>255</Color_Red>
        <Color_Green>255</Color_Green>
        <Color_Blue>255</Color_Blue>
        <Color_Alpha>1</Color_Alpha>
        <!--这个是光束的起点偏移，用于适配不同枪械长度的出口位置-->
        <StartPositionOffset_Range>0.15</StartPositionOffset_Range>
        <!--这个是造成伤害的类型-->
        <DamageDef>InfernoBeam</DamageDef>
        <!--这个是造成伤害的数值-->
        <DamageNum>2</DamageNum>
        <!--这个是护甲穿透-->
        <DamageArmorPenetration>1.52</DamageArmorPenetration>
		</li>
    </comps>
	</ThingDef>
	
