<Defs>
   <AbilityDef>
       <defName>CMC_NeutronPluse</defName>
       <label>neutron pulse</label>
       <description>The weapon releases a deadly pulse of accelerated neutrons.\n\nOnly cause damage to pawns.</description>
       <iconPath>UI/UI_NPulse</iconPath>
       <cooldownTicksRange>6000</cooldownTicksRange>
       <aiCanUse>true</aiCanUse>
       <verbProperties>
           <verbClass>Verb_CastAbility</verbClass>
           <range>7.9</range>
           <warmupTime>1</warmupTime>
           <soundCast>ChargeLance_Fire</soundCast>
           <targetParams>
               <canTargetLocations>true</canTargetLocations>
           </targetParams>
       </verbProperties>
       <comps>
           <li Class="TOT_DLL_test.CompProperties_AoEFist">
               <compClass>TOT_DLL_test.CompAbilityEffect_AoEFist</compClass>
               <range>7.9</range>
               <lineWidthEnd>9</lineWidthEnd>
               <SpawnFleck>CMC_NeutronBurst</SpawnFleck>
           </li>
       </comps>
   </AbilityDef>
   <EffecterDef>
       <defName>CMC_PulseWave</defName>
       <children>
           <li>
               <subEffecterClass>SubEffecter_SprayerChance</subEffecterClass>
               <positionRadius>0.15</positionRadius>
               <fleckDef>CMC_SparkFlash_Blue</fleckDef>
               <chancePerTick>0.9</chancePerTick>
               <speed>13.5</speed>
               <scale>2.3~2.7</scale>
               <angle>-15~15</angle>
               <positionLerpFactor>0.85</positionLerpFactor>
               <fleckUsesAngleForVelocity>true</fleckUsesAngleForVelocity>
           </li>
           <li>
               <subEffecterClass>SubEffecter_SprayerChance</subEffecterClass>
               <positionRadius>0.6</positionRadius>
               <fleckDef>CMC_SparkFlash</fleckDef>
               <chancePerTick>0.56</chancePerTick>
               <scale>1.2~1.4</scale>
               <positionLerpFactor>0.65</positionLerpFactor>
           </li>
           <li>
               <subEffecterClass>SubEffecter_SprayerChance</subEffecterClass>
               <positionRadius>0.6</positionRadius>
               <fleckDef>CMC_SparkFlash</fleckDef>
               <chancePerTick>0.76</chancePerTick>
               <scale>1.8~1.9</scale>
               <positionLerpFactor>0.65</positionLerpFactor>
           </li>
       </children>
   </EffecterDef>
   <AbilityDef>
       <defName>CMC_ShockwavePush</defName>
       <label>shockwave</label>
       <description>Releases a powerful shockwave that knocks back and stuns all nearby non-friendly units. Terrain obstacles will stop the knockback.</description>
       <iconPath>UI/UI_ShockWave</iconPath>
       <cooldownTicksRange>1800</cooldownTicksRange>
       <jobDef>CastAbilityOnThing</jobDef>
       <targetRequired>false</targetRequired>
       <canUseAoeToGetTargets>false</canUseAoeToGetTargets>
       <stunTargetWhileCasting>true</stunTargetWhileCasting>
       <showPsycastEffects>false</showPsycastEffects>
       <statBases>
           <Ability_Duration>0</Ability_Duration>
           <Ability_EffectRadius>5.9</Ability_EffectRadius>
       </statBases>
       <verbProperties>
           <verbClass>Verb_CastAbility</verbClass>
           <range>5.9</range>
           <requireLineOfSight>false</requireLineOfSight>
           <targetParams>
               <canTargetSelf>true</canTargetSelf>
               <canTargetPawns>false</canTargetPawns>
               <canTargetBuildings>false</canTargetBuildings>
               <canTargetLocations>false</canTargetLocations>
           </targetParams>
       </verbProperties>
       <comps>
           <li Class="TOT_DLL_test.CompProperties_Knockback">
               <knockbackDistance>2</knockbackDistance>
               <stunDuration>2.5</stunDuration>
           </li>
       </comps>
   </AbilityDef>
   <AbilityDef>
    <defName>CMC_UsePrecisionSkill</defName>
    <label>Initiate Calibration Protocol</label>
    <description>Activates the prism's remote control protocol. For a short duration, the weapon is guided directly by the fire control system, completely eliminating shooting spread.</description>
    <iconPath>UI/Chip_Ranged</iconPath>
    <hotKey>Misc12</hotKey>
	<cooldownTicksRange>6000~6000</cooldownTicksRange>
	<jobDef>CastAbilityOnThing</jobDef>
    <targetRequired>False</targetRequired>
    <canUseAoeToGetTargets>False</canUseAoeToGetTargets>
	<displayGizmoWhileUndrafted>True</displayGizmoWhileUndrafted>
    <disableGizmoWhileUndrafted>False</disableGizmoWhileUndrafted>
	<statBases>
	  <Ability_EffectRadius>0.9</Ability_EffectRadius>
      <Ability_Duration>300</Ability_Duration>
    </statBases>
    <verbProperties>
	  <verbClass>Verb_CastAbility</verbClass>
      <warmupTime>0.2</warmupTime>
      <range>2.9</range>
      <onlyManualCast>True</onlyManualCast>
      <targetParams>
        <canTargetSelf>True</canTargetSelf>
        <canTargetPawns>false</canTargetPawns>
        <canTargetBuildings>false</canTargetBuildings>
        <canTargetAnimals>false</canTargetAnimals>
        <canTargetHumans>false</canTargetHumans>
        <canTargetMechs>false</canTargetMechs>
      </targetParams>
    </verbProperties>
    <comps>
	  <li Class="CompProperties_AbilityGiveHediff">
        <compClass>CompAbilityEffect_GiveHediff</compClass>
        <hediffDef>TOT_PrecisionFocusBuff</hediffDef>
        <onlyApplyToSelf>true</onlyApplyToSelf>
        <replaceExisting>true</replaceExisting>
      </li>
    </comps>
  </AbilityDef>
</Defs>