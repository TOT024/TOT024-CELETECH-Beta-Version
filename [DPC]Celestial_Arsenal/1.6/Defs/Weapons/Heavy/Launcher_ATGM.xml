<Defs>
	<ThingDef ParentName="TOT_Weapons">
		<defName>CMC_HJX_ATGM</defName>
		<label>HJ301 ATGM launcher</label>
		<description>An advanced man-portable launcher utilizing auxiliary electromagnetic rail acceleration technology, firing advanced top-attack anti-tank missiles.\n\nNote: This launcher itself does not have an independent magazine and must rely on the B-HJ301 ATGM ammo pack for feeding and cycle reloading.</description>
		<techLevel>Spacer</techLevel>
		<uiIconPath>Things/Weapons/CMC_HJX_UI</uiIconPath>
		<graphicData>
		  <texPath>Things/Weapons/CMC_HJX</texPath>
		  <graphicClass>Graphic_Single</graphicClass>
		  <drawSize>(1,1)</drawSize>
		</graphicData>
		<recipeMaker>
		  <researchPrerequisite>CMC_Heavy_II</researchPrerequisite>
		  <skillRequirements>
			<Crafting>15</Crafting>
		  </skillRequirements>
		  <displayPriority>200</displayPriority>
		</recipeMaker>
		<costList>
			<Steel>30</Steel>
			<Plasteel>20</Plasteel>
			<ComponentSpacer>2</ComponentSpacer>
		</costList>
		<thingSetMakerTags>
		  <li>RewardStandardLowFreq</li>
		  <li>RewardStandardQualitySuper</li>
		</thingSetMakerTags>
		<tradeTags>
		  <li>WeaponRanged</li>
		</tradeTags>
		<weaponClasses>
		  <li>RangedHeavy</li>
		</weaponClasses>
		<weaponTags Inherit = "False">
		    <li>Weapon_CMCf</li>
			<li>GunHeavy</li>
			<li>Spacer</li>
		</weaponTags>
		<statBases>
		  <AccuracyTouch>1</AccuracyTouch>
		  <AccuracyShort>1</AccuracyShort>
		  <AccuracyMedium>1</AccuracyMedium>
		  <AccuracyLong>1</AccuracyLong>
		  <RangedWeapon_Cooldown>2.5</RangedWeapon_Cooldown>
		  <DeteriorationRate>0.9</DeteriorationRate>
		  <Mass>5.5</Mass>
		  <Flammability>0.9</Flammability>
		  <WorkToMake>35000</WorkToMake>
		</statBases>
    <verbs>
      <li>
        <verbClass>TOT_DLL_test.Verb_ShootWithWeaponAmmo</verbClass>
		<hasStandardCommand>true</hasStandardCommand>
		<warmupTime>2.25</warmupTime>
        <defaultProjectile>CMC_Missile_ATGM_Light</defaultProjectile>
		<forcedMissRadius>1.9</forcedMissRadius>
        <range>74.9</range>
        <burstShotCount>1</burstShotCount>
		<minRange>12.9</minRange>
        <targetParams>
          <canTargetPawns>true</canTargetPawns>
          <canTargetLocations>true</canTargetLocations>
          <canTargetBuildings>true</canTargetBuildings>
        </targetParams>
        <soundCast>RocketswarmLauncher_Fire</soundCast>
        <soundCastTail>GunTail_Heavy</soundCastTail>
        <muzzleFlashScale>24</muzzleFlashScale>
		<soundAiming>HellsphereCannon_Aiming</soundAiming>
		<requireLineOfSight>false</requireLineOfSight>
		<ai_IsBuildingDestroyer>true</ai_IsBuildingDestroyer>
      </li>
    </verbs>
	<equippedAngleOffset>45</equippedAngleOffset>
	<tools>
		  <li>
			<label>barrel</label>
			<capacities>
			  <li>Blunt</li>
			  <li>Poke</li>
			</capacities>
			<power>18</power>
			<cooldownTime>1.6</cooldownTime>
		  </li>
	</tools>
	<comps>
		<li Class="TOT_DLL_test.CompProperties_WeaponRenderStatic">
		<TexturePath>Things/Weapons/CMC_HJX_Light</TexturePath>
		</li>
		<li Class="TOT_DLL_test.CompProperties_WeaponAmmo">
			<maxMagAmmo>1</maxMagAmmo>
			<reloadTicks>356</reloadTicks>
			<defaultAutoSwapBack>false</defaultAutoSwapBack>
		</li>
	</comps>
	</ThingDef>
	<ThingDef ParentName="ApparelBase">
		<defName>CMC_ATGMAmmoPack</defName>
		<label>B-HJ301 ATGM ammo pack</label>
		<description>A tactical resupply backpack specifically designed for the HJ301 ATGM launcher. It contains 6 internal spare rounds and a micro-automatic loading mechanism. After the shooter fires, they simply need to attach the launcher to the side of the backpack, and the system will automatically complete the reloading process in the background. During this time, the shooter is free to reposition or engage with their sidearm.\n\nThis backpack comes standard with one HJ301 launcher upon manufacture. If the launcher is accidentally damaged or lost, an additional purchase is required.\n\n&lt;color=#FF5555>Safety Warnings&lt;/color>\n- Do not expose to open flames. The company is not responsible for casualties caused by ammunition cook-off.\n- Children aged 12 and under must operate under adult supervision.\n- Contains toxic propellant. Absolutely do not eat.</description>
		<techLevel>Spacer</techLevel>
		<tickerType>Normal</tickerType>
		<comps>
			<li Class="TOT_DLL_test.CompProperties_ApparelWeaponHolder">
				<useDefNameCheck>true</useDefNameCheck>
				<allowedDefNames>
					<li>CMC_HJX_ATGM</li>
				</allowedDefNames>
				<autoGenerateWeapon>true</autoGenerateWeapon>
				<TextWeaponSilhouetteTexPath>UI/CMC_ATGML_UI</TextWeaponSilhouetteTexPath>
			</li>
			<li Class="TOT_DLL_test.CompProperties_BackpackAmmo">
				<maxCharges>6</maxCharges>
				<ammoDef>Steel</ammoDef>
				<ammoCountPerCharge>30</ammoCountPerCharge>
				<baseReloadTicks>120</baseReloadTicks>
				<soundReload>Standard_Reload</soundReload>
				<chargeNoun>Ammo</chargeNoun>
			</li>
		</comps>
		<recipeMaker>
			<unfinishedThingDef>UnfinishedPack</unfinishedThingDef>
			<researchPrerequisite>CMC_Heavy_II</researchPrerequisite>
			<recipeUsers Inherit="False">
				<li>CMC_FacBench</li>
			</recipeUsers>
			<useIngredientsForColor>false</useIngredientsForColor>
			<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
			<workSkill>Crafting</workSkill>
			<effectWorking>Smith</effectWorking>
			<soundWorking>Recipe_Machining</soundWorking>
			<skillRequirements>
				<Crafting>4</Crafting>
			</skillRequirements>
			<displayPriority>330</displayPriority>
		</recipeMaker>
		<costList>
			<Steel>150</Steel>
			<Plasteel>30</Plasteel>
			<Chemfuel>100</Chemfuel>
			<ComponentIndustrial>12</ComponentIndustrial>
			<ComponentSpacer>6</ComponentSpacer>
		</costList>
		<graphicData>
			<texPath>Things/Apparel/Back_Aux/CMC_ATGMAmmoPack_display</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<shaderType>CutoutComplex</shaderType>
		</graphicData>
		<tickerType>Normal</tickerType>
		<statBases>
			<ArmorRating_Sharp>0.32</ArmorRating_Sharp>
