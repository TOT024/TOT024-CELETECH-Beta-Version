<Defs>
	<ThingDef ParentName="TOT_Weapons">
		<defName>CMC_RocketLauncher</defName>
		<label>PF201 recoilless rifle(backpack-fed)</label>
		<description>A man-portable recoilless rifle utilizing auxiliary electromagnetic rail acceleration technology. Thanks to the electromagnetic assist, its projectile velocity and effective range far exceed those of traditional similar weapons. However, due to its extremely flat trajectory, it is only capable of direct-fire and cannot fire over walls or tall obstacles.\n\nNote: This launcher itself does not have an independent magazine and must rely on the B-PF120 Recoilless Rifle Ammo Pack for feeding and cycle reloading.</description>
		<techLevel>Spacer</techLevel>
		<tickerType>Normal</tickerType>
		<uiIconPath>Things/Weapons/CMC_RLSingleuseMKII_UI</uiIconPath>
		<graphicData>
			<texPath>Things/Weapons/CMC_RLSingleuseMKII</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>(1.1,1.1)</drawSize>
		</graphicData>
		<destroyOnDrop>False</destroyOnDrop>
		<recipeMaker>
			<researchPrerequisite>CMC_Heavy_I</researchPrerequisite>
			<skillRequirements>
				<Crafting>8</Crafting>
			</skillRequirements>
			<displayPriority>180</displayPriority>
		</recipeMaker>
		<costList>
			<Steel>30</Steel>
			<Plasteel>20</Plasteel>
			<ComponentSpacer>1</ComponentSpacer>
		</costList>
		<thingSetMakerTags>
			<li>RewardStandardLowFreq</li>
			<li>RewardStandardQualitySuper</li>
		</thingSetMakerTags>
		<tradeTags>
			<li>WeaponRanged</li>
		</tradeTags>
		<weaponClasses>
			<li>RangedHeavy</li>
		</weaponClasses>
		<weaponTags Inherit = "False">
			<li>Weapon_CMCf</li>
			<li>Spacer</li>
			<li>GunHeavy</li>
		</weaponTags>
		<statBases>
			<AccuracyTouch>0.98</AccuracyTouch>
			<AccuracyShort>0.92</AccuracyShort>
			<AccuracyMedium>0.82</AccuracyMedium>
			<AccuracyLong>0.75</AccuracyLong>
			<RangedWeapon_Cooldown>1.55</RangedWeapon_Cooldown>
			<DeteriorationRate>0.9</DeteriorationRate>
			<Mass>4.8</Mass>
			<Flammability>1.4</Flammability>
			<WorkToMake>35000</WorkToMake>
		</statBases>
		<verbs>
			<li>
				<verbClass>TOT_DLL_test.Verb_ShootWithWeaponAmmo</verbClass>
				<hasStandardCommand>true</hasStandardCommand>
				<warmupTime>2.01</warmupTime>
				<defaultProjectile>CMC_FF120Rocket</defaultProjectile>
				<forcedMissRadius>0.9</forcedMissRadius>
				<range>49.9</range>
				<burstShotCount>1</burstShotCount>
				<onlyManualCast>false</onlyManualCast>
				<minRange>8.9</minRange>
				<targetParams>
					<canTargetPawns>true</canTargetPawns>
					<canTargetLocations>true</canTargetLocations>
					<canTargetBuildings>true</canTargetBuildings>
				</targetParams>
				<soundCast>RocketswarmLauncher_Fire</soundCast>
				<soundCastTail>GunTail_Heavy</soundCastTail>
				<muzzleFlashScale>24</muzzleFlashScale>
				<soundAiming>HellsphereCannon_Aiming</soundAiming>
			</li>
		</verbs>
		<equippedAngleOffset>45</equippedAngleOffset>
		<tools>
			<li>
				<label>barrel</label>
				<capacities>
					<li>Blunt</li>
					<li>Poke</li>
				</capacities>
				<power>28</power>
				<cooldownTime>2.6</cooldownTime>
			</li>
		</tools>
		<comps>
			<li Class="CompProperties_Explosive">
				<explosiveRadius>3.9</explosiveRadius>
				<explosiveDamageType>Bomb</explosiveDamageType>
				<requiredDamageTypeToExplode>Flame</requiredDamageTypeToExplode>
			</li>
			<li Class="TOT_DLL_test.CompProperties_WeaponRenderStatic">
				<TexturePath>Things/Weapons/CMC_RLSingleuseMKII_Light</TexturePath>
			</li>
			<li Class="TOT_DLL_test.CompProperties_WeaponAmmo">
				<maxMagAmmo>1</maxMagAmmo>
				<reloadTicks>462</reloadTicks>
				<defaultAutoSwapBack>false</defaultAutoSwapBack>
			</li>
		</comps>
	</ThingDef>
	<ThingDef ParentName="ApparelBase">
		<defName>CMC_RCAmmoPack</defName>
		<label>B-PF201 recoilless rifle ammo pack</label>
		<description>A tactical resupply backpack specifically designed for the PF201 recoilless rifle. It contains 7 internal spare rounds and a micro-automatic loading mechanism. After the shooter fires, they simply need to attach the launcher to the side of the backpack, and the system will automatically complete the reloading process in the background. During this time, the shooter is free to reposition or engage with their sidearm.\n\nThis backpack comes standard with one PF120 launcher upon manufacture. If the launcher is accidentally damaged or lost, an additional purchase is required.\n\n&lt;color=#FF5555>Safety Warnings&lt;/color>\n- Do not expose to open flames. The company is not responsible for casualties caused by ammunition cook-off.\n- Children aged 12 and under must operate under adult supervision.\n- Contains toxic propellant. Absolutely do not eat.</description>
		<techLevel>Spacer</techLevel>
		<tickerType>Normal</tickerType>
		<comps>
			<li Class="TOT_DLL_test.CompProperties_ApparelWeaponHolder">
				<useDefNameCheck>true</useDefNameCheck>
				<allowedDefNames>
					<li>CMC_RocketLauncher</li>
				</allowedDefNames>
				<autoGenerateWeapon>true</autoGenerateWeapon>
				<TextWeaponSilhouetteTexPath>UI/CMC_RL_UI</TextWeaponSilhouetteTexPath>
			</li>
			<li Class="TOT_DLL_test.CompProperties_BackpackAmmo">
				<maxCharges>7</maxCharges>
				<ammoDef>Steel</ammoDef>
				<ammoCountPerCharge>20</ammoCountPerCharge>
				<baseReloadTicks>360</baseReloadTicks>
				<soundReload>Standard_Reload</soundReload>
				<chargeNoun>Ammo</chargeNoun>
			</li>
		</comps>
		<recipeMaker>
			<unfinishedThingDef>UnfinishedPack</unfinishedThingDef>
			<researchPrerequisite>CMC_Heavy_I</researchPrerequisite>
			<recipeUsers Inherit="False">
