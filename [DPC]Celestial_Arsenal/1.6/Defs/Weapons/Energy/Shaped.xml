<Defs>
  <ThingDef ParentName="TOT_Weapons_WithGizmo">
    <defName>CMC_ShapedLaserRifle</defName>
    <label>QBZL-55 particle beam rifle</label>
    <description>First generation of particle beam rifle, which is able to penetrate its target with energized particle. It is very effective against close-ranged targets.</description>
	<uiIconPath>Things/Weapons/CMC_SLR_UI</uiIconPath>
	<tickerType>Normal</tickerType>
    <graphicData>
      <texPath>Things/Weapons/CMC_SLR</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>1.12</drawSize>
    </graphicData>
    <uiIconScale>1</uiIconScale>
    <soundInteract>Interact_Rifle</soundInteract>
	<generateCommonality>0.001</generateCommonality>
	<recipeMaker>
      <researchPrerequisite>CMC_DEWII</researchPrerequisite>
	<skillRequirements>
        <Crafting>8</Crafting>
      </skillRequirements>
    </recipeMaker>
    <statBases>
	  <WorkToMake>10000</WorkToMake>
      <Mass>9.5</Mass>
      <RangedWeapon_Cooldown>0.65</RangedWeapon_Cooldown>
	  <MarketValue>3600</MarketValue>
    </statBases>
	<costList>
      <Steel>75</Steel>
	  <Plasteel>75</Plasteel>
      <ComponentIndustrial>5</ComponentIndustrial>
	  <ComponentSpacer>5</ComponentSpacer>
      <Silver>20</Silver>
    </costList>
    <weaponTags>
      <li>SpacerGun</li>
    </weaponTags>
    <verbs>
      <li>
        <verbClass>TOT_DLL_test.Verb_Laser_Sustain</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <warmupTime>0.23</warmupTime>
        <range>28</range>
        <!--这个是攻击次数-->
        <burstShotCount>120</burstShotCount>
        <!--这个是攻击间隔-->
        <ticksBetweenBurstShots>2</ticksBetweenBurstShots>
        <soundCastTail>GunTail_Medium</soundCastTail>
        <muzzleFlashScale>0</muzzleFlashScale>
      </li>
    </verbs>
	<comps>
      <li Class="TOT_DLL_test.CompProperties_LaserData_Sustain">
        <!--激光光束样式-->
        <LaserLine_MoteDef>CMC_Laser_Stay_MoteBlue</LaserLine_MoteDef>
        <!--光束末端的效果+基础大小-->
        <LaserFleck_End>CMC_Laser_Stay_LaserEndLarge_TT</LaserFleck_End>
        <!--光束基础大小-->
        <LaserFleck_End_Scale_Base>8.0</LaserFleck_End_Scale_Base>
        <!--光束末端粒子的效果+基础大小+大小偏移量+数量+产生几率-->
        <LaserFleck_Spark>CMC_Stay_Laser_Spark</LaserFleck_Spark>
        <!--光束末端粒子的基础大小-->
        <LaserFleck_Spark_Scale_Base>0.3</LaserFleck_Spark_Scale_Base>
        <!--光束末端粒子大小偏移量-->
        <LaserFleck_Spark_Scale_Deviation>0.2</LaserFleck_Spark_Scale_Deviation>
        <!--光束末端粒子数量-->
        <LaserFleck_Spark_Num>3</LaserFleck_Spark_Num>
        <!--光束末端粒子产生几率-->
        <LaserFleck_Spark_Spawn_Chance>0.4</LaserFleck_Spark_Spawn_Chance>
        <!--这是开火时的音效-->
        <SoundDef>CMC_LaserSustainSound</SoundDef>
        <!--这是光束颜色调整（直接输入数值0-255）+不透明度（0-1）（如果是已经上好色的激光贴图的话，全部颜色写成255应该就行）-->
        <Color_Red>255</Color_Red>
        <Color_Green>255</Color_Green>
        <Color_Blue>255</Color_Blue>
        <Color_Alpha>1</Color_Alpha>
        <!--这个是光束的起点偏移，用于适配不同枪械长度的出口位置-->
        <StartPositionOffset_Range>0.35</StartPositionOffset_Range>
        <!--这个是造成伤害的类型-->
        <DamageDef>InfernoBeam</DamageDef>
        <!--这个是造成伤害的数值-->
        <DamageNum>3</DamageNum>
        <!--这个是护甲穿透-->
        <DamageArmorPenetration>1.22</DamageArmorPenetration>
		</li>
		<li Class="TOT_DLL_test.CompProperties_WeaponRenderStatic">
			<TexturePath>Things/Weapons/CMC_SLR_Light</TexturePath>
			<TexturePath_Camo>Things/Weapons/CMC_SLRm</TexturePath_Camo>
		</li>
		<li Class="TOT_DLL_test.CompProperties_AccessoryHolder">
			<maxAccessories>1</maxAccessories>
			<allowedAccessoryDefs>
				<li>CMC_Accessory_EMBooster_Psy</li>
			</allowedAccessoryDefs>
		</li>
		<li Class="TOT_DLL_test.CompProperties_LaserHeat">
			<maxHeat>100</maxHeat>
			<heatPerBurstShot>2</heatPerBurstShot>
			<coolPerTick>1</coolPerTick>
			<overheatBackswingTicks>120</overheatBackswingTicks>
		</li>
    </comps>
	<tools>
      <li>
        <label>stock</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>12</power>
        <cooldownTime>2</cooldownTime>
      </li>
      <li>
        <label>barrel</label>
        <capacities>
          <li>Blunt</li>
          <li>Poke</li>
        </capacities>
        <power>19</power>
        <cooldownTime>2</cooldownTime>
		<extraMeleeDamages>
          <li>
            <def>Flame</def>
            <amount>10</amount>
            <chance>0.6</chance>
          </li>
		</extraMeleeDamages>
      </li>
    </tools>
  </ThingDef>
  
  <ThingDef ParentName="MoteBase">
    <defName>MYDE_FlashingOfSwordEffect</defName>
    <graphicData>
      <texPath>Things/Projectile/FlashingOfSwordEffect</texPath>
      <shaderType>MoteGlow</shaderType>
    </graphicData>
    <altitudeLayer>Projectile</altitudeLayer>
    <rotatable>false</rotatable>
    <mote>
      <fadeInTime>1.9</fadeInTime>
      <!--淡入时间-->
      <solidTime>0</solidTime>
      <!--曝光时间-->
      <fadeOutTime>0.4</fadeOutTime>
      <!--淡出时间-->
    </mote>
	<drawOffscreen>true</drawOffscreen>
  </ThingDef>
  
