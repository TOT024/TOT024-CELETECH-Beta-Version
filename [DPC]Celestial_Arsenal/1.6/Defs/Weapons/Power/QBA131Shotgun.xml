<Defs>
<ThingDef ParentName="TOT_Weapons">
    <defName>CMC_QBAfournine</defName>
    <label>QBA-131R shotgun</label>
    <description>The QBA-131R utilizes twin-barrel magnetic rail acceleration technology to propel four fragmenting tungsten alloy penetrators at hyper-velocities. It possesses devastating piercing capabilities against projectile interceptors and composite armor. The trade-offs are its tremendous recoil and an archaic mechanical reloading system that compromises sustained fire rates.</description>
	<uiIconPath>Things/Weapons/CMC_QBX57CSG_UI</uiIconPath>
    <graphicData>
      <texPath>Things/Weapons/CMC_QBX57CSG</texPath>
      <graphicClass>Graphic_Single</graphicClass>
	  <drawSize>(1.29,1.29)</drawSize>
    </graphicData>
    <soundInteract>Interact_ChargeLance</soundInteract>
    <recipeMaker>
      <researchPrerequisite>CMC_EMweaponTech_I</researchPrerequisite>
      <skillRequirements>
        <Crafting>8</Crafting>
      </skillRequirements>
      <displayPriority>405</displayPriority>
    </recipeMaker>
    <weaponTags>
      <li>SpacerGun</li>
    </weaponTags>
    <weaponClasses>
	  <li>ShortShots</li>
    </weaponClasses>
    <statBases>
      <WorkToMake>23000</WorkToMake>
      <Mass>4.12</Mass>
      <AccuracyTouch>0.80</AccuracyTouch>
      <AccuracyShort>0.70</AccuracyShort>
      <AccuracyMedium>0.60</AccuracyMedium>
      <AccuracyLong>0.50</AccuracyLong>
      <RangedWeapon_Cooldown>1.86</RangedWeapon_Cooldown>
    </statBases>
    <costList>
      <Steel>70</Steel>
	  <Plasteel>25</Plasteel>
      <ComponentIndustrial>2</ComponentIndustrial>
	  <ComponentSpacer>2</ComponentSpacer>
    </costList>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>Bullet_QBAFourNine</defaultProjectile>
        <warmupTime>0.74</warmupTime>
        <range>14.9</range>
		<burstShotCount>1</burstShotCount>
        <soundCast>Shot_Shotgun</soundCast>
        <soundCastTail>GunTail_Heavy</soundCastTail>
        <muzzleFlashScale>9</muzzleFlashScale>
      </li>
    </verbs>
    <tools>
      <li>
        <label>barrel</label>
        <capacities>
          <li>Blunt</li>
          <li>Poke</li>
        </capacities>
        <power>13</power>
        <cooldownTime>2</cooldownTime>
      </li>
    </tools>
