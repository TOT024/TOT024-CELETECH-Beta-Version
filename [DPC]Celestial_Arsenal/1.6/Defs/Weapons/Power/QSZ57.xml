<Defs>
  <ThingDef ParentName="TOT_WeaponsNoQuality">
    <defName>CMC_QSZfiveseven</defName>
    <label>QSZ-57 PDW</label>
    <description>A personal-defense weapon based on ancient blowback-operated self-loading pistol. It is light to carry and quick to fire, which makes it popular among pilots and frontier explorers. Its speciallized bullets can delay targets' motion.</description>
    <graphicData>
      <texPath>Things/Weapons/QSZfiveseven</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <uiIconPath>Things/Weapons/QSZfiveseven_UI</uiIconPath>
    <uiIconScale>1.1</uiIconScale>
    <soundInteract>Interact_Autopistol</soundInteract>
    <recipeMaker>
      <researchPrerequisite>CMC_basisLight</researchPrerequisite>
      <skillRequirements>
        <Crafting>4</Crafting>
      </skillRequirements>
      <displayPriority>405</displayPriority>
    </recipeMaker>
    <weaponTags>
      <li>SpacerGun</li>
      <li>CMC_PDW</li>
    </weaponTags>
    <weaponClasses>
      <li>RangedLight</li>
    </weaponClasses>
    <statBases>
      <WorkToMake>5000</WorkToMake>
      <Mass>2.2</Mass>
      <AccuracyTouch>0.88</AccuracyTouch>
      <AccuracyShort>0.72</AccuracyShort>
      <AccuracyMedium>0.65</AccuracyMedium>
      <AccuracyLong>0.53</AccuracyLong>
      <RangedWeapon_Cooldown>0.96</RangedWeapon_Cooldown>
      <MarketValue>1200</MarketValue>
    </statBases>
    <costList>
      <Steel>75</Steel>
      <ComponentIndustrial>10</ComponentIndustrial>
      <Chemfuel>15</Chemfuel>
    </costList>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>CMC_Bullet_pistol</defaultProjectile>
        <warmupTime>1.7</warmupTime>
        <range>19.9</range>
        <burstShotCount>20</burstShotCount>
        <ticksBetweenBurstShots>4</ticksBetweenBurstShots>
        <soundCast>Shot_Revolver</soundCast>
        <soundCastTail>GunTail_Light</soundCastTail>
        <muzzleFlashScale>9</muzzleFlashScale>
      </li>
    </verbs>
    <comps>
      <li Class="TOT_DLL_test.CompProperties_WeaponRenderStatic">
        <TexturePath>Things/Weapons/QSZfiveseven_Light</TexturePath>
        <TexturePath_Camo>Things/Weapons/QSZfivesevenm</TexturePath_Camo>
      </li>
      <li Class="TOT_DLL_test.CompProperties_AccessoryHolder">
        <maxAccessories>2</maxAccessories>
        <allowedAccessoryDefs>
          <li>CMC_Accessory_AdvancedScope</li>
          <li>CMC_Accessory_AdvancedScopeB</li>
        </allowedAccessoryDefs>
      </li>
    </comps>
    <tools>
      <li>
        <label>grip</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>9</power>
        <cooldownTime>2</cooldownTime>
      </li>
    </tools>
  </ThingDef>
  
