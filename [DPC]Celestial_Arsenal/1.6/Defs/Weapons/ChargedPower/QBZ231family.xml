<Defs>
    <ThingDef ParentName="TOT_Weapons">
        <defName>QBZ_fivenine</defName>
        <label>QBZ-231 AR</label>
        <description>A small-caliber charged assault rifle specifically developed for close-quarters combat environments such as spaceships, capable of firing 4mm charged rounds at an extremely high rate of fire. Although the caliber is small and the power of individual shots is limited, the weapon's exceptionally high rate of fire allows it to effectively suppress enemies.</description>
        <graphicData>
            <texPath>Things/Weapons/QBZfivenine</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>(1.19,1.19)</drawSize>
        </graphicData>
        <uiIconPath>Things/Weapons/QBZfivenine_UI</uiIconPath>
        <soundInteract>Interact_ChargeLance</soundInteract>
        <recipeMaker>
            <researchPrerequisite>CMC_EMweaponTech_II</researchPrerequisite>
            <skillRequirements>
                <Crafting>10</Crafting>
            </skillRequirements>
        </recipeMaker>
        <thingSetMakerTags>
            <li>RewardStandardQualitySuper</li>
        </thingSetMakerTags>
        <statBases>
            <WorkToMake>35000</WorkToMake>
            <Mass>6.4</Mass>
            <AccuracyTouch>0.85</AccuracyTouch>
            <AccuracyShort>0.73</AccuracyShort>
            <AccuracyMedium>0.69</AccuracyMedium>
            <AccuracyLong>0.61</AccuracyLong>
            <RangedWeapon_Cooldown>1.3</RangedWeapon_Cooldown>
            <MarketValue>2100</MarketValue>
        </statBases>
        <costList>
            <Steel>75</Steel>
            <Plasteel>60</Plasteel>
            <ComponentIndustrial>4</ComponentIndustrial>
            <ComponentSpacer>2</ComponentSpacer>
            <Chemfuel>15</Chemfuel>
        </costList>
        <weaponClasses>
            <li>RangedHeavy</li>
        </weaponClasses>
        <weaponTags>
            <li>SpacerGun</li>
            <li>CMC_Charged</li>
        </weaponTags>
        <verbs>
            <li>
                <verbClass>Verb_Shoot</verbClass>
                <hasStandardCommand>true</hasStandardCommand>
                <defaultProjectile>Bullet_QBZfivenine</defaultProjectile>
                <warmupTime>0.89</warmupTime>
                <range>32</range>
                <burstShotCount>12</burstShotCount>
                <ticksBetweenBurstShots>5</ticksBetweenBurstShots>
                <soundCast>STi</soundCast>
                <soundCastTail>GunTail_Medium</soundCastTail>
                <muzzleFlashScale>9</muzzleFlashScale>
            </li>
        </verbs>
        <comps>
            <li Class="TOT_DLL_test.CompProperties_WeaponRenderStatic">
                <TexturePath>Things/Weapons/QBZfivenine_Light</TexturePath>
                <TexturePath_Camo>Things/Weapons/QBZfiveninem</TexturePath_Camo>
            </li>
			<li Class="TOT_DLL_test.CompProperties_AccessoryHolder">
				<maxAccessories>2</maxAccessories>
				<allowedAccessoryDefs>
					<li>CMC_Accessory_AdvancedScope</li>
					<li>CMC_Accessory_EMBooster</li>
					<li>CMC_Accessory_EMBooster_Psy</li>
				</allowedAccessoryDefs>
			</li>
        </comps>
        <tools>
            <li>
                <label>stock</label>
                <capacities>
                    <li>Blunt</li>
                </capacities>
                <power>9</power>
                <cooldownTime>2</cooldownTime>
            </li>
            <li>
