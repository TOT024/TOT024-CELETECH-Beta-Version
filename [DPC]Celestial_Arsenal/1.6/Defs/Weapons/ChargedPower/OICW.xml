<Defs>
   <ThingDef ParentName="TOT_Weapons_WithGizmo">
       <defName>QBZ71_QS</defName>
       <label>QTS-214 OICW</label>
       <description>An individual weapon system that accomodates a grenade launcher, an assault rifle and an advanced balistic computer.</description>
       <uiIconPath>Things/Weapons/QBZsevenone_UI</uiIconPath>
       <graphicData>
           <texPath>Things/Weapons/QBZsevenone</texPath>
           <graphicClass>Graphic_Single</graphicClass>
           <drawSize>(1.4,1.4)</drawSize>
       </graphicData>
       <drawerType>MapMeshAndRealTime</drawerType>
       <soundInteract>Interact_Rifle</soundInteract>
       <generateCommonality>0.03</generateCommonality>
       <equippedStatOffsets>
           <MoveSpeed>-0.36</MoveSpeed>
       </equippedStatOffsets>
       <weaponClasses>
           <li>RangedHeavy</li>
       </weaponClasses>
       <weaponTags Inherit="False">
           <li>SpacerGun</li>
           <li>CMC_Charged_Grenade</li>
       </weaponTags>
       <tradeTags>
           <li>WeaponRanged</li>
       </tradeTags>
       <statBases>
           <WorkToMake>60000</WorkToMake>
           <Mass>11.7</Mass>
           <RangedWeapon_Cooldown>1.35</RangedWeapon_Cooldown>
           <AccuracyTouch>1</AccuracyTouch>
           <AccuracyShort>0.95</AccuracyShort>
           <AccuracyMedium>0.9</AccuracyMedium>
           <AccuracyLong>0.84</AccuracyLong>
           <MarketValue>3200</MarketValue>
       </statBases>
       <costList>
           <Steel>125</Steel>
           <Plasteel>75</Plasteel>
           <Uranium>25</Uranium>
           <ComponentIndustrial>12</ComponentIndustrial>
           <ComponentSpacer>5</ComponentSpacer>
           <Chemfuel>20</Chemfuel>
           <Gold>3</Gold>
       </costList>
       <recipeMaker>
           <skillRequirements>
               <Crafting>9</Crafting>
           </skillRequirements>
           <researchPrerequisites>
               <li>CMC_EMweaponTech_I</li>
               <li>CMC_Heavy_I</li>
           </researchPrerequisites>
           <displayPriority>470</displayPriority>
       </recipeMaker>
       <verbs>
           <li>
               <verbClass>Verb_Shoot</verbClass>
               <burstShotCount>6</burstShotCount>
               <ticksBetweenBurstShots>6</ticksBetweenBurstShots>
               <hasStandardCommand>true</hasStandardCommand>
               <defaultProjectile>Bullet_QBZfivenine</defaultProjectile>
               <warmupTime>0.53</warmupTime>
               <range>43.9</range>
               <soundCast>STi</soundCast>
               <soundCastTail>GunTail_Medium</soundCastTail>
               <muzzleFlashScale>19</muzzleFlashScale>
           </li>
       </verbs>
       <comps>
           <li Class="TOT_DLL_test.CompProperties_SecondaryVerb_Rework">
               <mainWeaponLabel>rifle</mainWeaponLabel>
               <mainCommandIcon>UI/UI_Sniper</mainCommandIcon>
               <secondaryWeaponLabel>grenade</secondaryWeaponLabel>
               <secondaryCommandIcon>UI/UI_SG</secondaryCommandIcon>
               <description>Using grenade launcher to fire stun grenades that incapables enemy.</description>
               <verbProps>
                   <verbClass>Verb_Shoot</verbClass>
                   <hasStandardCommand>true</hasStandardCommand>
                   <defaultProjectile>CMC_LightRocketGrenade</defaultProjectile>
                   <warmupTime>2.33</warmupTime>
                   <range>39.9</range>
                   <soundCast>Shot_MiniFlameblaster</soundCast>
                   <soundCastTail>GunTail_Heavy</soundCastTail>
                   <muzzleFlashScale>29</muzzleFlashScale>
                   <minRange>4.9</minRange>
                   <forcedMissRadius>0.9</forcedMissRadius>
                   <targetParams>
                       <canTargetLocations>true</canTargetLocations>
                       <canTargetPawns>true</canTargetPawns>
                   </targetParams>
                   <burstShotCount>1</burstShotCount>
                   <canGoWild>false</canGoWild>
               </verbProps>
           </li>
		   <li Class="TOT_DLL_test.CompProperties_PawnEquipmentGizmo"/>
           <li Class="TOT_DLL_test.CompProperties_WeaponRenderStatic">
               <TexturePath>Things/Weapons/QBZsevenone_Light</TexturePath>
               <TexturePath_Camo>Things/Weapons/QBZsevenonem</TexturePath_Camo>
           </li>
           <li Class="TOT_DLL_test.CompProperties_AccessoryHolder">
               <maxAccessories>2</maxAccessories>
               <allowedAccessoryDefs>
                   <li>CMC_Accessory_AdvancedScope</li>
                   <li>CMC_Accessory_AdvancedScopeB</li>
                   <li>CMC_Accessory_EMBooster</li>
                   <li>CMC_Accessory_EMBooster_Psy</li>
               </allowedAccessoryDefs>
           </li>
       </comps>
       <tools>
           <li>
               <label>stock</label>
               <capacities>
                   <li>Blunt</li>
               </capacities>
               <power>15</power>
               <cooldownTime>2</cooldownTime>
           </li>
           <li>
               <label>barrel</label>
               <capacities>
                   <li>Blunt</li>
                   <li>Poke</li>
               </capacities>
               <power>14</power>
               <cooldownTime>2</cooldownTime>
           </li>
       </tools>
   </ThingDef>
