<Defs>
	<ThingDef ParentName="BuildingBase">
		<defName>CMC_ReinforcedBunker</defName>
		<label>pop-up HMG bastion</label>
		<thingClass>TOT_DLL_test.Building_Bunker</thingClass>
		<drawerType>MapMeshAndRealTime</drawerType>
		<tickerType>Normal</tickerType>
		<terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
		<description>A subterranean bastion cloaked in neutron-charged plating, impervious to directed energy weapons including plasma cannons. When health drops below 25% or it is one holdfire mode, it descends for repairs - consuming 50 steel and quadruple power every 10 seconds to restore 100 HP. Though its suppressive fire lacks precision, the tortoise-shell armor renders it nigh indestructible against frontal assaults.</description>
		<uiIconPath>Things/Buildings/BunkerB_Display</uiIconPath>
		<graphicData>
			<texPath>Things/Buildings/Bunker_New_Base</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>(4.8,4.8)</drawSize>
		</graphicData>
		<altitudeLayer>Building</altitudeLayer>
		<size>(3,3)</size>
		<statBases>
			<MaxHitPoints>10000</MaxHitPoints>
			<Flammability>0</Flammability>
			<ShootingAccuracyTurret>0.87</ShootingAccuracyTurret>
			<WorkToBuild>12000</WorkToBuild>
		</statBases>
		<killedLeavings>
			<ChunkSlagSteel>2</ChunkSlagSteel>
			<Steel>60</Steel>
		</killedLeavings>
		<costList>
			<Steel>800</Steel>
			<Plasteel>150</Plasteel>
			<ComponentIndustrial>5</ComponentIndustrial>
			<ComponentSpacer>1</ComponentSpacer>
			<Uranium>120</Uranium>
		</costList>
		<comps>
			<li Class="CompProperties_Forbiddable"/>
			<li Class="CompProperties_Flickable"/>
			<li Class="CompProperties_Breakdownable"/>
			<li Class="CompProperties_Refuelable">
				<fuelLabel>Shots until barrel change</fuelLabel>
				<fuelGizmoLabel>Barrel durability</fuelGizmoLabel>
				<outOfFuelMessage>Needs new barrel</outOfFuelMessage>
				<fuelFilter>
					<thingDefs>
						<li>Steel</li>
					</thingDefs>
				</fuelFilter>
				<fuelCapacity>2000</fuelCapacity>
				<fuelMultiplier>10</fuelMultiplier>
				<initialFuelPercent>1</initialFuelPercent>
				<autoRefuelPercent>0.8</autoRefuelPercent>
				<showFuelGizmo>true</showFuelGizmo>
				<minimumFueledThreshold>1</minimumFueledThreshold>
				<factorByDifficulty>true</factorByDifficulty>
				<consumeFuelOnlyWhenUsed>true</consumeFuelOnlyWhenUsed>
				<fuelIconPath>UI/Overlays/Barrel</fuelIconPath>
			</li>
			<li Class="CompProperties_AffectedByFacilities">
				<linkableFacilities>
					<li>CMC_FCradar</li>
				</linkableFacilities>
			</li>
			<li Class="CompProperties_Power">
				<compClass>CompPowerTrader</compClass>
				<basePowerConsumption>200</basePowerConsumption>
			</li>
			<li Class="TOT_DLL_test.CompProperties_TurretLifter">
				<texturePath>Things/Buildings/Bunker_New_LiftB</texturePath>
				<doorLeftTexturePath>Things/Buildings/Bunker_Left</doorLeftTexturePath>
				<doorRightTexturePath>Things/Buildings/Bunker_Right</doorRightTexturePath>
				<ticksToFull>600</ticksToFull>
				<textureScale>(2.5, 2.5)</textureScale>
				<drawOffset>(0, 0, -1.2)</drawOffset>
				<doorSize>(2.65,2.65)</doorSize>
				<doorOffset>(0, 0, 0)</doorOffset>
				<yOffset>0.05</yOffset>
				<gunSize>(5.33, 5.33)</gunSize>
				<barrelSize>(5.33, 5.33)</barrelSize>
				<barrelExtensionDist>0</barrelExtensionDist>
				<gunTopTexturePath>Things/CMC_Void</gunTopTexturePath>
				<gunBarrelTexturePath>Things/CMC_Void</gunBarrelTexturePath>
			</li>
		</comps>
		<damageMultipliers>
			<li>
				<damageDef>Arrow</damageDef>
				<multiplier>0</multiplier>
			</li>
			<li>
				<damageDef>Vaporize</damageDef>
				<multiplier>0.5</multiplier>
			</li>
			<li>
				<damageDef>EMP</damageDef>
				<multiplier>0</multiplier>
			</li>
			<li>
				<damageDef>Stun</damageDef>
				<multiplier>0</multiplier>
			</li>
		</damageMultipliers>
		<building>
			<turretGunDef>Gun_BunkerHMG</turretGunDef>
			<turretTopDrawSize>1.2</turretTopDrawSize>
			<turretBurstCooldownTime>1.5</turretBurstCooldownTime>
		</building>
		<researchPrerequisites>
			<li>CMCGunTurretsbasic</li>
		</researchPrerequisites>
		<designationCategory>CMC_DefensenProduction</designationCategory>
		<placeWorkers>
			<li>PlaceWorker_BandNode</li>
		</placeWorkers>
		<modExtensions>
			<li Class="TOT_DLL_test.TurretExtension_CMC">
				<rotationSpeed>1</rotationSpeed>
			</li>
		</modExtensions>
	</ThingDef>
