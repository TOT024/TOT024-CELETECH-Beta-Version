  <ThingDef ParentName="BaseWeaponTurret">
    <defName>CMC_Gun_SAML</defName>
    <label>Type-CX Missile launcher</label>
    <description>A self-loading missile launcher designed to attach to a turret.</description>
    <graphicData>
      <texPath>Things/Buildings/CMC_SamTurret_Top</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(5,5)</drawSize>
    </graphicData>
    <statBases>
      <AccuracyTouch>1</AccuracyTouch>
      <AccuracyShort>1</AccuracyShort>
      <AccuracyMedium>1</AccuracyMedium>
      <AccuracyLong>1</AccuracyLong>
      <RangedWeapon_Cooldown>1.0</RangedWeapon_Cooldown>
      <DeteriorationRate>0</DeteriorationRate>
      <Mass>400</Mass>
      <Flammability>0</Flammability>
    </statBases>
	        <weaponTags Inherit = "False">
			<li>Weapon_CMCf</li>
		</weaponTags>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <defaultProjectile>CMC_SAM_Proj</defaultProjectile>
        <range>120</range>
		<forcedMissRadius>0.1</forcedMissRadius>
        <burstShotCount>1</burstShotCount>
		<requireLineOfSight>false</requireLineOfSight>
        <soundCast>Sound_rocketlauncher_heavy</soundCast>
        <soundCastTail>GunTail_Heavy</soundCastTail>
        <muzzleFlashScale>74</muzzleFlashScale>
        <consumeFuelPerShot>1</consumeFuelPerShot>
		<targetParams>
          <canTargetPawns>true</canTargetPawns>
          <canTargetLocations>true</canTargetLocations>
          <canTargetBuildings>true</canTargetBuildings>
        </targetParams>
      </li>
    </verbs>
  </ThingDef>
  <ThingDef ParentName="BaseBullet">
        <defName>CMC_SAM_Proj</defName>
        <label>HQ-12</label>
        <graphicData>
            <texPath>Things/CMC_Void</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>(1.2, 1.2)</drawSize>
        </graphicData>
        <thingClass>TOT_DLL_test.Projectile_RocketAntiAir</thingClass>
        <projectile>
            <damageDef>Bomb</damageDef>
            <speed>140</speed>
            <screenShakeFactor>0</screenShakeFactor>
            <damageAmountBase>10</damageAmountBase>
            <flyOverhead>true</flyOverhead>
            <armorPenetrationBase>0.3</armorPenetrationBase>
            <soundHitThickRoof>Artillery_HitThickRoof</soundHitThickRoof>
            <soundImpactAnticipate>MortarRound_PreImpact</soundImpactAnticipate>
            <soundAmbient>MortarRound_Ambient</soundAmbient>
            <shadowSize>0</shadowSize>
        </projectile>
    </ThingDef>
	
