<Defs>
	<ThingDef ParentName="AutocannonTurret">
    <defName>CMC_SAML</defName>
    <label>SAM turret</label>
	<thingClass>TOT_DLL_test.Building_CMCTurretGun_AAAS</thingClass>
    <description>.</description>
    <uiIconPath>Things/Buildings/CMC_SAM_UI</uiIconPath>
	<graphicData>
        <texPath>Things/Buildings/largebase_SAM</texPath>
        <graphicClass>Graphic_Single</graphicClass>
        <drawSize>(5.1,5.1)</drawSize>
    </graphicData>
	<size>(3,3)</size>
	<drawerType>MapMeshAndRealTime</drawerType>
    <altitudeLayer>Building</altitudeLayer>
    <stealable>false</stealable>
    <rotatable>false</rotatable>
	<tickerType>Normal</tickerType>
    <techLevel>Spacer</techLevel>
    <statBases>
	  <MaxHitPoints>4000</MaxHitPoints>
	  <Flammability>1.5</Flammability>
      <ShootingAccuracyTurret>0.2</ShootingAccuracyTurret>
	  <WorkToBuild>8000</WorkToBuild>
    </statBases>
	<killedLeavings>
      <ChunkSlagSteel>2</ChunkSlagSteel>
      <Steel>30</Steel>
      <Plasteel>10</Plasteel>
    </killedLeavings>
    <costList>
      <Steel>1200</Steel>
	  <Plasteel>320</Plasteel>
      <ComponentIndustrial>8</ComponentIndustrial>
	  <ComponentSpacer>10</ComponentSpacer>
    </costList>
    <comps>
      <li Class="CompProperties_Explosive">
        <wickTicks>0</wickTicks>
        <explosiveRadius>9.9</explosiveRadius>
		<explosiveExpandPerFuel>2</explosiveExpandPerFuel>
        <explosiveDamageType>Bomb</explosiveDamageType>
        <chanceNeverExplodeFromDamage>0</chanceNeverExplodeFromDamage>
      </li>
      <li Class="CompProperties_Forbiddable"/>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>3300</basePowerConsumption>
      </li>
      <li Class="CompProperties_Flickable"/>
      <li Class="CompProperties_Breakdownable"/>
      <li Class="CompProperties_Refuelable">
        <fuelLabel>Shots until barrel change</fuelLabel>
        <fuelGizmoLabel>Ammo</fuelGizmoLabel>
        <outOfFuelMessage>Needs missile</outOfFuelMessage>
        <fuelFilter><thingDefs><li>ComponentIndustrial</li></thingDefs></fuelFilter>
        <fuelCapacity>54</fuelCapacity>
        <fuelMultiplier>1</fuelMultiplier>
        <initialFuelPercent>1</initialFuelPercent>
        <autoRefuelPercent>0.99</autoRefuelPercent>
        <showFuelGizmo>true</showFuelGizmo>
        <minimumFueledThreshold>1</minimumFueledThreshold>
        <factorByDifficulty>false</factorByDifficulty>
        <consumeFuelOnlyWhenUsed>true</consumeFuelOnlyWhenUsed>
        <fuelIconPath>UI/Overlays/Barrel</fuelIconPath>
      </li>
    </comps>
	<damageMultipliers>
      <li>
        <damageDef>Bomb</damageDef>
        <multiplier>1.2</multiplier>
      </li>
      <li>
        <damageDef>Bullet</damageDef>
        <multiplier>0.8</multiplier>
      </li>
	  <li>
        <damageDef>EMP</damageDef>
        <multiplier>0</multiplier>
      </li>
	  <li>
        <damageDef>Stun</damageDef>
        <multiplier>0</multiplier>
      </li>
    </damageMultipliers>
    <building>
      <turretGunDef>CMC_Gun_SAML</turretGunDef>
      <turretBurstCooldownTime>2</turretBurstCooldownTime>
	  <turretTopDrawSize>5.9</turretTopDrawSize>
    </building>
    <researchPrerequisites>
      <li>CMC_Heavy_II</li>
	  <li>CMCGunTurrets</li>
    </researchPrerequisites>
	<terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
    <placeWorkers Inherit="False">
        <li>PlaceWorker_TurretTop</li>
    </placeWorkers>
	<modExtensions>
	  <li Class="TOT_DLL_test.TurretExtension_CMC">
        <rotationSpeed>3.6</rotationSpeed>
		<frameCount>19</frameCount>
		<turrettopspritePath>Things/Buildings/SAM_PT</turrettopspritePath>
      </li>
    </modExtensions>
	<designationCategory>CMC_DefensenProduction</designationCategory>
  </ThingDef>
  
