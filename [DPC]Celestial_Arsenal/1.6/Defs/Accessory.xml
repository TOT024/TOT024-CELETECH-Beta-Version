   <ThingDef ParentName="CMC_AccessoryBase">
       <defName>CMC_Accessory_EMBooster</defName>
       <label>Auxiliary EM Booster</label>
       <description>An external magnetic coil module. It utilizes high-voltage electromagnetic fields to supercharge projectiles, significantly increasing impact damage at the cost of increased weight and aiming time.\n\nCompatible with select electromagnetic weapons.\n\n**Special Ability:** Overloads the coils to release a shockwave, knocking back and stunning nearby enemies.\n\n&lt;color=#D20103&gt;[CELETECH Group Disclaimer: Frequent overcharging may lead to catastrophic structural failure. We accept no liability for damages resulting from the use of sub-standard weapons or uncertified modifications!]&lt;/color&gt;</description>
       <graphicData>
           <texPath>Things/Others/CMC_Accesory_EMComponent</texPath>
       </graphicData>
       <statBases>
           <Mass>1</Mass>
           <MarketValue>450</MarketValue>
           <WorkToMake>2500</WorkToMake>
       </statBases>
       <costList>
           <Steel>50</Steel>
           <ComponentIndustrial>2</ComponentIndustrial>
       </costList>
       <comps>
           <li Class="TOT_DLL_test.CompProperties_AccessoryStats">
               <stats>
                   <li>
                       <stat>Mass</stat>
                       <modifier>Add</modifier>
                       <value>1.0</value>
                   </li>
                   <li>
                       <stat>RangedWeapon_DamageMultiplier</stat>
                       <modifier>Add</modifier>
                       <value>0.15</value>
                   </li>
                   <li>
                       <stat>RangedWeapon_Cooldown</stat>
                       <modifier>Add</modifier>
                       <value>0.2</value>
                   </li>
               </stats>
			   <abilities>
                   <li>
                       <AbilityDef>CMC_ShockwavePush</AbilityDef>
                   </li>
               </abilities>
           </li>
       </comps>
   </ThingDef>
   <ThingDef ParentName="CMC_AdvAccessoryBase">
       <defName>CMC_Accessory_EMBooster_Psy</defName>
       <label>Psy-Resonator</label>
       <description>Modified EM booster tuned to resonate with psychic frequencies. Enhances damage output while retaining standard drawbacks.\n\n**Extra Effects: 0.5% chance to clear psychic entropy when weapon installed with this accessory is fired. 100% chance to gain a maximum of 6% psychic focus after an enemy is killed.</description>
       <graphicData>
           <texPath>Things/Others/CMC_Accesory_EMComponent_Psy</texPath>
       </graphicData>
       <statBases>
           <Mass>1</Mass>
           <MarketValue>450</MarketValue>
           <WorkToMake>3500</WorkToMake>
       </statBases>
       <costList>
           <Steel>50</Steel>
           <ComponentIndustrial>2</ComponentIndustrial>
           <Jade>10</Jade>
       </costList>
       <comps>
           <li Class="TOT_DLL_test.CompProperties_AccessoryStats">
               <stats>
                   <li>
                       <stat>Mass</stat>
                       <modifier>Add</modifier>
                       <value>1.0</value>
                   </li>
                   <li>
                       <stat>RangedWeapon_DamageMultiplier</stat>
                       <modifier>Add</modifier>
                       <value>0.15</value>
                   </li>
                   <li>
                       <stat>RangedWeapon_Cooldown</stat>
                       <modifier>Add</modifier>
                       <value>0.2</value>
                   </li>
               </stats>
           </li>
		   <li Class="TOT_DLL_test.CompProperties_AccessoryEffect_GainFocus">
				<triggerChanceFire>0.005</triggerChanceFire>
			</li>
       </comps>
   </ThingDef>
   <ThingDef ParentName="CMC_AdvAccessoryBase">
       <defName>CMC_Accessory_Prism</defName>
       <label>Advanced Prism Module</label>
       <description>A replacement prism module for pulse laser weapons. Equipped with additional heat sinks, it significantly reduces warm up and cool down time.\n\n**Special Ability:** Activates a remote control protocol that takes over prism deflection for a duration, completely eliminating weapon spread.</description>
       <graphicData>
           <texPath>Things/Others/CMC_Accesory_prism</texPath>
       </graphicData>
       <statBases>
           <Mass>1</Mass>
           <MarketValue>450</MarketValue>
           <WorkToMake>3500</WorkToMake>
       </statBases>
       <costList>
           <Steel>50</Steel>
           <ComponentIndustrial>2</ComponentIndustrial>
           <Jade>10</Jade>
       </costList>
       <comps>
           <li Class="TOT_DLL_test.CompProperties_AccessoryStats">
               <stats>
                   <li>
                       <stat>Mass</stat>
                       <modifier>Add</modifier>
                       <value>0.22</value>
                   </li>
                   <li>
                       <stat>RangedWeapon_Cooldown</stat>
                       <modifier>Multiply</modifier>
                       <value>0.67</value>
                   </li>
				   <li>
                       <stat>RangedWeapon_WarmupMultiplier</stat>
                       <modifier>Multiply</modifier>
                       <value>0.75</value>
                   </li>
				   <li>
                       <stat>RangedWeapon_RangeMultiplier</stat>
                       <modifier>Add</modifier>
                       <value>0.45</value>
                   </li>
               </stats>
			   <abilities>
                   <li>
                       <AbilityDef>CMC_UsePrecisionSkill</AbilityDef>
                   </li>
               </abilities>
           </li>
