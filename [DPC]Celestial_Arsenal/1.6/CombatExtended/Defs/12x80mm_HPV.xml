<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingCategoryDef>
    <defName>AmmoCategory_CMC_12x80mmSmart</defName>
    <label>12x80mm MTS</label>
    <parent>AmmoAdvanced</parent>
    <iconPath>Things/Ammo/12x80mmUI</iconPath>
  </ThingCategoryDef>

  <!-- ==================== AmmoSet ========================== -->

  <CombatExtended.AmmoSetDef>
    <defName>AmmoSet_CMC_12x80mmSmart</defName>
    <label>12x80mm MTS</label>
    <ammoTypes>
      <Ammo_CMC_12x80mmSmart_Regular>Bullet_CMC_12x80mmSmart_Regular</Ammo_CMC_12x80mmSmart_Regular>
    </ammoTypes>
  </CombatExtended.AmmoSetDef>

  <!-- ==================== Ammo ========================== -->

  <ThingDef Class="CombatExtended.AmmoDef" Name="Ammo_CMC_12x80mmSmart_Base" ParentName="SpacerMediumAmmoBase" Abstract="True">
    <description>12x80mm multi-task smart ammo by CeleTech</description>
    <statBases>
      <Mass>0.11</Mass>
      <Bulk>0.03</Bulk>
    </statBases>
    <tradeTags>
      <li>CE_AutoEnableTrade</li>
      <li>CE_AutoEnableCrafting_TableMachining</li>
      <li>CE_AutoEnableCrafting_CMC_FacBench</li>
    </tradeTags>
    <thingCategories>
      <li>AmmoCategory_CMC_12x80mmSmart</li>
    </thingCategories>
  </ThingDef>

  <ThingDef Class="CombatExtended.AmmoDef" ParentName="Ammo_CMC_12x80mmSmart_Base">
    <defName>Ammo_CMC_12x80mmSmart_Regular</defName>
    <label>CMC_12x80mmSmart R</label>
    <graphicData>
      <texPath>Things/Ammo/12x80mm_R</texPath>
      <graphicClass>Verse.Graphic_StackCount</graphicClass>
    </graphicData>
    <ammoClass>CMC_HomingHPVBullet</ammoClass>
    <cookOffProjectile>Bullet_CMC_12x80mmSmart_Regular</cookOffProjectile>
  </ThingDef>

  <!-- ================== Projectiles ================== -->

  <ThingDef Name="Bullet_CMC_12x80mmSmart_Base" ParentName="BaseBulletCE" Abstract="True">
    <graphicData>
      <texPath>Things/Projectile/Charge_Small</texPath>
      <graphicClass>Verse.Graphic_Single</graphicClass>
    </graphicData>
    <thingClass>CeleTechXCE_DLL.ProjectileGuidedBulletCE</thingClass>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <speed>354</speed>
      <damageDef>Bullet</damageDef>
      <dropsCasings>true</dropsCasings>
    </projectile>
  </ThingDef>

  <ThingDef ParentName="Bullet_CMC_12x80mmSmart_Base">
    <defName>Bullet_CMC_12x80mmSmart_Regular</defName>
    <thingClass>CeleTechXCE_DLL.ProjectileGuidedBulletCE</thingClass>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageAmountBase>69</damageAmountBase>
      <armorPenetrationSharp>130</armorPenetrationSharp>
      <armorPenetrationBlunt>6250</armorPenetrationBlunt>
      <secondaryDamage>
        <li>
          <def>EMP</def>
          <amount>15</amount>
        </li>
        <li>
          <def>Bomb_Secondary</def>
          <amount>12</amount>
        </li>
      </secondaryDamage>
    </projectile>
  </ThingDef>

  <!-- ==================== Recipes ========================== -->

  <RecipeDef ParentName="AmmoRecipeBase">
    <defName>MakeAmmo_CMC_12x80mmSmart_Regular</defName>
    <label>make CMC_12x80mmSmart R cartridge x200</label>
    <description>Craft 200 CMC_12x80mmSmart R cartridges.</description>
    <jobString>Making CMC_12x80mmSmart R cartridges.</jobString>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>FSX</li>
          </thingDefs>
        </filter>
        <count>5</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ComponentSpacer</li>
          </thingDefs>
        </filter>
        <count>2</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Plasteel</li>
          </thingDefs>
        </filter>
        <count>10</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Uranium</li>
          </thingDefs>
        </filter>
        <count>20</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>FSX</li>
        <li>ComponentSpacer</li>
        <li>Plasteel</li>
        <li>Uranium</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <Ammo_CMC_12x80mmSmart_Regular>200</Ammo_CMC_12x80mmSmart_Regular>
    </products>
    <workAmount>2000</workAmount>
  </RecipeDef>
</Defs>