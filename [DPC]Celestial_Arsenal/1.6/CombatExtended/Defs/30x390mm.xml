      <damageAmountBase>188</damageAmountBase>
      <armorPenetrationBlunt>45000</armorPenetrationBlunt>
      <armorPenetrationSharp>506</armorPenetrationSharp>
      <secondaryDamage>
        <li>
          <def>EMP</def>
          <amount>60</amount>
        </li>
      </secondaryDamage>
    </projectile>
  </ThingDef>

