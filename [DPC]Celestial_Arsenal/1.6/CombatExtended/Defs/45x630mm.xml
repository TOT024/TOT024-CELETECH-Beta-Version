    <jobString>Making CMC_Ammo_45x630mm HE cartridges.</jobString>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>FSX</li>
          </thingDefs>
        </filter>
        <count>50</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>ComponentIndustrial</li>
          </thingDefs>
        </filter>
        <count>20</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Plasteel</li>
          </thingDefs>
        </filter>
        <count>50</count>
      </li>
      <li>
				<filter>
					<thingDefs>
						<li>Uranium</li>
					</thingDefs>
				</filter>
				<count>180</count>
			</li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>FSX</li>
        <li>ComponentIndustrial</li>
        <li>Plasteel</li>
        <li>Uranium</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <Ammo_CMC_Ammo_45x630mm_APHE>50</Ammo_CMC_Ammo_45x630mm_APHE>
    </products>
    <workAmount>30000</workAmount>
  </RecipeDef>

