<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingCategoryDef>
    <defName>AmmoCategory_CMC_Ammo_45x630mm</defName>
    <label>45x630mm Electromagnetic</label>
    <parent>AmmoShells</parent>
    <iconPath>Things/Ammo/45x250mmUI</iconPath>
  </ThingCategoryDef>

  <!-- ==================== AmmoSet ========================== -->

  <CombatExtended.AmmoSetDef>
    <defName>AmmoSet_CMC_Ammo_45x630mm</defName>
    <label>45x630mm Electromagnetic</label>
    <ammoTypes>
      <Ammo_CMC_Ammo_45x630mm_APHE>Bullet_CMC_Ammo_45x630mm_APHE</Ammo_CMC_Ammo_45x630mm_APHE>
      <Ammo_CMC_Ammo_45x630mm_APDS-EMP>Bullet_CMC_Ammo_45x630mm_APDS-EMP</Ammo_CMC_Ammo_45x630mm_APDS-EMP>
    </ammoTypes>
  </CombatExtended.AmmoSetDef>

  <!-- ==================== Ammo ========================== -->

  <ThingDef Class="CombatExtended.AmmoDef" Name="Ammo_CMC_Ammo_45x630mm_Base" ParentName="HeavyAmmoBase" Abstract="True">
    <description>High caliber EM-shell</description>
    <statBases>
      <Mass>0.99</Mass>
      <Bulk>3.01</Bulk>
    </statBases>
    <tradeTags>
      <li>CE_AutoEnableTrade</li>
      <li>CE_AutoEnableCrafting_TableMachining</li>
      <li>CE_AutoEnableCrafting_CMC_FacBench</li>
    </tradeTags>
    <thingCategories>
      <li>AmmoCategory_CMC_Ammo_45x630mm</li>
    </thingCategories>
  </ThingDef>

  <ThingDef Class="CombatExtended.AmmoDef" ParentName="Ammo_CMC_Ammo_45x630mm_Base">
    <defName>Ammo_CMC_Ammo_45x630mm_APHE</defName>
    <label>CMC_Ammo_45x630mm APHE</label>
    <graphicData>
      <texPath>Things/Ammo/45x250mm_HE</texPath>
      <graphicClass>Verse.Graphic_StackCount</graphicClass>
    </graphicData>
    <ammoClass>GrenadeHE</ammoClass>
    <cookOffProjectile>Bullet_CMC_Ammo_45x630mm_APHE</cookOffProjectile>
  </ThingDef>

  <ThingDef Class="CombatExtended.AmmoDef" ParentName="Ammo_CMC_Ammo_45x630mm_Base">
    <defName>Ammo_CMC_Ammo_45x630mm_APDS-EMP</defName>
    <label>CMC_Ammo_45x630mm APDS-EMP</label>
    <graphicData>
      <texPath>Things/Ammo/45x250mm_EMP</texPath>
      <graphicClass>Verse.Graphic_StackCount</graphicClass>
    </graphicData>
    <ammoClass>Sabot</ammoClass>
    <cookOffProjectile>Bullet_CMC_Ammo_45x630mm_APDS-EMP</cookOffProjectile>
  </ThingDef>

  <!-- ================== Projectiles ================== -->

  <ThingDef Name="Bullet_CMC_Ammo_45x630mm_Base" ParentName="BaseBulletCE" Abstract="True">
    <graphicData>
      <texPath>Things/Projectile/Bullet_QLUX</texPath>
      <graphicClass>Verse.Graphic_Single</graphicClass>
    </graphicData>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <speed>456</speed>
      <damageDef>Bullet</damageDef>
      <dropsCasings>true</dropsCasings>
    </projectile>
  </ThingDef>

  <ThingDef ParentName="Bullet_CMC_Ammo_45x630mm_Base">
    <defName>Bullet_CMC_Ammo_45x630mm_APHE</defName>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageAmountBase>441</damageAmountBase>
      <armorPenetrationBlunt>110250</armorPenetrationBlunt>
      <armorPenetrationSharp>277</armorPenetrationSharp>
    </projectile>
    <comps>
      <li Class="CombatExtended.CompProperties_ExplosiveCE">
        <damageAmountBase>147</damageAmountBase>
        <explosiveDamageType>Bomb</explosiveDamageType>
        <explosiveRadius>2.5</explosiveRadius>
      </li>
    </comps>
  </ThingDef>

  <ThingDef ParentName="Bullet_CMC_Ammo_45x630mm_Base">
    <defName>Bullet_CMC_Ammo_45x630mm_APDS-EMP</defName>
    <projectile Class="CombatExtended.ProjectilePropertiesCE">
      <damageAmountBase>294</damageAmountBase>
      <damageDef>BulletAoE_Void</damageDef>
      <armorPenetrationBlunt>110250</armorPenetrationBlunt>
      <armorPenetrationSharp>832</armorPenetrationSharp>
      <secondaryDamage>
        <li>
          <def>EMP</def>
          <amount>98</amount>
        </li>
      </secondaryDamage>
    </projectile>
    <comps>
      <li Class="CombatExtended.CompProperties_ExplosiveCE">
        <damageAmountBase>60</damageAmountBase>
        <explosiveDamageType>EMP</explosiveDamageType>
        <explosiveRadius>3.5</explosiveRadius>
      </li>
    </comps>
  </ThingDef>

  <!-- ==================== Recipes ========================== -->

