    <fixedIngredientFilter>
      <thingDefs>
        <li>ComponentSpacer</li>
        <li>ComponentIndustrial</li>
        <li>Plasteel</li>
        <li>Uranium</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <Ammo_CMC_20x220mmSmart_Regular>100</Ammo_CMC_20x220mmSmart_Regular>
    </products>
    <workAmount>12000</workAmount>
