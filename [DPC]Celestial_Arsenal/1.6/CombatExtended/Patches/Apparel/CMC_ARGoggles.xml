<?xml version="1.0" encoding="utf-8"?>
<Patch>

  <Operation Class="PatchOperationReplace">
    <xpath>Defs/ThingDef[defName="CMC_ARGoggles"]/apparel/layers</xpath>
    <value>
      <layers>
        <li>StrappedHead</li>
      </layers>
    </value>
  </Operation>

  <Operation Class="PatchOperationAdd">
    <xpath>Defs/ThingDef[defName="CMC_ARGoggles"]/equippedStatOffsets</xpath>
    <value>
      <NightVisionEfficiency>1</NightVisionEfficiency>
      <AimingAccuracy>1.5</AimingAccuracy>
      <SmokeSensitivity>-0.9</SmokeSensitivity>
      <Suppressability>-0.85</Suppressability>
    </value>
  </Operation>

</Patch>